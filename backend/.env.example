# Azure OpenAI Configuration
# Get these from your Azure Portal: https://portal.azure.com
# Navigate to: Azure OpenAI Resource > Keys and Endpoint

# Your Azure OpenAI endpoint (e.g., https://your-resource-name.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# Your Azure OpenAI API key (Key 1 or Key 2 from Azure Portal)
AZURE_OPENAI_API_KEY=your-api-key-here

# Your deployment name for GPT-5.1 (created in Azure OpenAI Studio)
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-51

# Your deployment name for text embeddings (e.g., text-embedding-ada-002 or text-embedding-3-small)
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-ada-002

# API version (use the latest stable version)
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# Server Configuration
PORT=3001

# CORS Configuration (comma-separated allowed origins)
ALLOWED_ORIGINS=http://localhost:5173,https://asathyanesan.github.io
